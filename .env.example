# Copy to .env and fill in values (never commit .env)

# LinkedIn — OpenID "sub" from https://api.linkedin.com/v2/userinfo
LINKEDIN_PERSON_ID=YOUR_PERSON_ID

# LinkedIn REST API version header (default: 202502 — proven for image posts)
# Override if LinkedIn deprecates: https://learn.microsoft.com/en-us/linkedin/marketing/versioning
LINKEDIN_API_VERSION=202502

# n8n
N8N_HOST=localhost
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/

# Optional — or configure in n8n Credentials UI
# OPENAI_API_KEY=sk-...

# Webhook auth — set in production (pass as X-Webhook-Secret header)
WEBHOOK_SECRET=generate-a-long-random-secret

# Docker basic auth (change in production!)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme